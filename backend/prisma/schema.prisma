generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  firebaseUid   String    @unique
  normalizedEmail String?
  normalizedPhone String?
  username      String    @unique
  displayName   String
  avatarUrl     String?
  bio           String?
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  activities    Activity[]
  authIdentities AuthIdentity[]
  coachProfile  CoachProfile?
  trainingGoals TrainingGoal[]
  trainingPlans TrainingPlan[]
  plannedWorkouts PlannedWorkout[]
  workoutCompletions WorkoutCompletion[]
  readinessCheckIns ReadinessCheckIn[]
  athleteTrainingStates AthleteTrainingState[]
  planningEvents PlanningEvent[]
  planAdjustmentEvents PlanAdjustmentEvent[]
  posts         Post[]
  following     Follow[]  @relation("follower")
  followers     Follow[]  @relation("following")
  reactions     Reaction[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model AuthIdentity {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  firebaseUid     String    @unique
  providerId      String
  signInProvider  String?
  providerIds     String[]  @default([])

  email           String?
  normalizedEmail String?
  emailVerified   Boolean   @default(false)
  phoneNumber     String?
  normalizedPhone String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model CoachProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])

  // Coach identity
  coachName       String    @default("Coach")
  personality     String    @default("encouraging")  // encouraging | data-driven | direct | zen
  voiceId         String    @default("default")

  // Athlete snapshot (rebuilt after each activity)
  fitnessLevel    String    @default("beginner")     // beginner | intermediate | advanced | elite
  weeklyVolumeKm  Float     @default(0)
  preferredPace   Float?    // seconds per km
  strengths       String[]  @default([])
  weaknesses      String[]  @default([])

  // Goals
  goals           Json      @default("[]")           // GoalItem[]

  // Personal records
  records         Json      @default("{}")           // { "5k": seconds, "10k": seconds, ... }

  // Coaching memory — compressed history for on-device context
  memorySnapshot  Json      @default("{}")           // last 30 days summary
  lastBuiltAt     DateTime?

  // Downloadable artifact version
  version         Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Activity {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  clientActivityId String?
  syncSource    String?   // ios-local-store, watch-import, manual

  type          String    // running | cycling | hiking | swimming
  title         String?
  startedAt     DateTime
  endedAt       DateTime?
  durationSecs  Int?
  distanceM     Float?
  elevationM    Float?
  avgPace       Float?    // secs/km
  avgHeartRate  Int?
  calories      Int?

  route         Json?     // GeoJSON Feature with LineString geometry
  splits        Json?     // Split[]
  reflection    Json?     // post-activity finish reflection saved by the client
  photos        Photo[]
  posts         Post[]
  workoutCompletions WorkoutCompletion[]

  // AI coach analysis generated after activity
  coachAnalysis Json?

  createdAt     DateTime  @default(now())

  @@unique([userId, clientActivityId])
}

model TrainingPlanTemplate {
  id                     String    @id
  focus                  String
  sport                  String
  title                  String
  subtitle               String
  defaultWeeks           Int
  minSessionsPerWeek     Int
  maxSessionsPerWeek     Int
  baseWeeklyMinutes      Int
  baseLongSessionMinutes Int
  summary                String
  highlights             String[]  @default([])
  source                 Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  weeks                  TrainingPlanWeek[]

  @@index([focus])
  @@index([sport])
}

model TrainingPlanWeek {
  id          String    @id @default(cuid())
  templateId  String
  template    TrainingPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sourceId    String
  weekIndex   Int
  focus       String
  summary     String
  notes       String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workouts    TrainingPlanWorkout[]

  @@unique([templateId, sourceId])
  @@unique([templateId, weekIndex])
  @@index([templateId])
}

model TrainingPlanWorkout {
  id              String    @id @default(cuid())
  weekId          String
  week            TrainingPlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  sourceId        String
  sortOrder       Int
  title           String
  kind            String
  dayLabel        String
  summary         String
  purpose         String
  coachCue        String
  effortLabel     String
  durationSeconds Int
  distanceLabel   String?
  isOptional      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  steps           TrainingPlanWorkoutStep[]

  @@unique([weekId, sourceId])
  @@index([weekId, sortOrder])
}

model TrainingPlanWorkoutStep {
  id              String    @id @default(cuid())
  workoutId       String
  workout         TrainingPlanWorkout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sourceId        String
  sortOrder       Int
  kind            String
  label           String
  durationSeconds Int
  detail          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([workoutId, sourceId])
  @@index([workoutId, sortOrder])
}

model TrainingGoal {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 String
  primaryModality      String
  targetDate           DateTime?
  targetDistanceMeters Float?
  targetEventName      String?
  priority             String
  preferredDays        String[]  @default([])
  daysPerWeekTarget    Int       @default(3)
  maxSessionMinutes    Int       @default(45)
  riskTolerance        String    @default("balanced")
  constraints          Json      @default("{}")
  status               String    @default("active")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  plans                TrainingPlan[]

  @@index([userId, status])
}

model TrainingPlan {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId         String
  goal           TrainingGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  status         String    @default("active")
  currentPhase   String    @default("base")
  source         String    @default("generated")
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  versions       TrainingPlanVersion[]

  @@index([userId, status])
  @@index([goalId])
}

model TrainingPlanVersion {
  id              String    @id @default(cuid())
  planId          String
  plan            TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  versionNumber   Int
  reason          String
  effectiveFrom   DateTime  @default(now())
  effectiveUntil  DateTime?
  summary         String
  engineInputs    Json      @default("{}")
  engineDecision  Json      @default("{}")
  createdAt       DateTime  @default(now())

  workouts        PlannedWorkout[]

  @@unique([planId, versionNumber])
  @@index([planId, createdAt])
}

model PlannedWorkout {
  id                String    @id @default(cuid())
  planVersionId     String
  planVersion       TrainingPlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledDate     DateTime
  modality          String
  stimulus          String
  title             String
  durationSeconds   Int
  distanceMeters    Float?
  intensityModel    String
  intensityTarget   Json?
  prescription      Json      @default("{}")
  isKeyWorkout      Boolean   @default(false)
  status            String    @default("planned")
  replacesWorkoutId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  blocks            WorkoutBlock[]
  completions       WorkoutCompletion[]

  @@index([userId, scheduledDate])
  @@index([planVersionId, scheduledDate])
  @@index([status])
}

model WorkoutBlock {
  id               String    @id @default(cuid())
  plannedWorkoutId String
  plannedWorkout   PlannedWorkout @relation(fields: [plannedWorkoutId], references: [id], onDelete: Cascade)
  sortOrder        Int
  blockType        String
  modality         String
  stimulus         String
  durationSeconds  Int?
  distanceMeters   Float?
  repeats          Int?
  restSeconds      Int?
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  steps            WorkoutStep[]

  @@index([plannedWorkoutId, sortOrder])
}

model WorkoutStep {
  id              String    @id @default(cuid())
  blockId         String
  block           WorkoutBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  sortOrder       Int
  label           String
  kind            String
  durationSeconds Int?
  distanceMeters  Float?
  target          Json?
  detail          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([blockId, sortOrder])
}

model WorkoutCompletion {
  id                String    @id @default(cuid())
  plannedWorkoutId  String
  plannedWorkout    PlannedWorkout @relation(fields: [plannedWorkoutId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityId        String?
  activity          Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  completedAt       DateTime  @default(now())
  durationSeconds   Int?
  distanceMeters    Float?
  avgPace           Float?
  avgHeartRate      Int?
  avgPower          Float?
  perceivedEffort   Int?
  completionQuality String    @default("completed")
  notes             String?
  createdAt         DateTime  @default(now())

  @@index([userId, completedAt])
  @@index([plannedWorkoutId])
  @@index([activityId])
}

model ReadinessCheckIn {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime
  energy        Int       @default(3)
  soreness      Int       @default(1)
  sleepQuality  Int       @default(3)
  stress        Int       @default(1)
  motivation    Int       @default(3)
  illnessOrPain Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())

  @@index([userId, date])
}

model AthleteTrainingState {
  id                          String    @id @default(cuid())
  userId                      String
  user                        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asOfDate                    DateTime
  overallLoadScore            Float     @default(0)
  fatigueRisk                 String    @default("low")
  consistencyScore            Float     @default(0)
  adherenceRate               Float     @default(0)
  weeklyMinutes               Int       @default(0)
  weeklyDistanceMeters        Float     @default(0)
  fourWeekAvgMinutes          Int       @default(0)
  fourWeekAvgDistanceMeters   Float     @default(0)
  longestRecentSessionSeconds Int       @default(0)
  lastHardWorkoutAt           DateTime?
  modalityBreakdown           Json      @default("{}")
  createdAt                   DateTime  @default(now())

  @@index([userId, asOfDate])
}

model PlanningEvent {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId       String?
  type         String
  sourceId     String?
  payload      Json      @default("{}")
  status       String    @default("pending")
  priority     Int       @default(0)
  dedupeKey    String?
  runAfter     DateTime  @default(now())
  attemptCount Int       @default(0)
  lastError    String?
  createdAt    DateTime  @default(now())
  processedAt  DateTime?

  @@index([status, runAfter, priority])
  @@index([userId, status])
  @@index([dedupeKey, status])
}

model PlanAdjustmentEvent {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId            String
  fromVersionId     String?
  toVersionId       String?
  eventType         String
  message           String
  changedWorkoutIds String[]  @default([])
  engineInputs      Json      @default("{}")
  engineDecision    Json      @default("{}")
  createdAt         DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([planId, createdAt])
}

model Photo {
  id          String    @id @default(cuid())
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id])
  url         String
  takenAt     DateTime
  // Stats at moment of capture
  paceAtShot  Float?
  hrAtShot    Int?
  distAtShot  Float?
  lat         Float?
  lng         Float?
  createdAt   DateTime  @default(now())
}

model Post {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  activityId  String?
  activity    Activity?  @relation(fields: [activityId], references: [id])
  caption     String?
  createdAt   DateTime   @default(now())
  reactions   Reaction[]
  comments    Comment[]
}

model Follow {
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id])
  following   User   @relation("following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
  type      String   // fire | clap | heart | strong
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  body      String
  createdAt DateTime @default(now())
}
