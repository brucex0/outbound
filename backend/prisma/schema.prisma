generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  firebaseUid   String    @unique
  normalizedEmail String?
  normalizedPhone String?
  username      String    @unique
  displayName   String
  avatarUrl     String?
  bio           String?
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  activities    Activity[]
  authIdentities AuthIdentity[]
  coachProfile  CoachProfile?
  activeTrainingPlan ActiveTrainingPlan?
  posts         Post[]
  following     Follow[]  @relation("follower")
  followers     Follow[]  @relation("following")
  reactions     Reaction[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model AuthIdentity {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  firebaseUid     String    @unique
  providerId      String
  signInProvider  String?
  providerIds     String[]  @default([])

  email           String?
  normalizedEmail String?
  emailVerified   Boolean   @default(false)
  phoneNumber     String?
  normalizedPhone String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model CoachProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])

  // Coach identity
  coachName       String    @default("Coach")
  personality     String    @default("encouraging")  // encouraging | data-driven | direct | zen
  voiceId         String    @default("default")

  // Athlete snapshot (rebuilt after each activity)
  fitnessLevel    String    @default("beginner")     // beginner | intermediate | advanced | elite
  weeklyVolumeKm  Float     @default(0)
  preferredPace   Float?    // seconds per km
  strengths       String[]  @default([])
  weaknesses      String[]  @default([])

  // Goals
  goals           Json      @default("[]")           // GoalItem[]

  // Personal records
  records         Json      @default("{}")           // { "5k": seconds, "10k": seconds, ... }

  // Coaching memory — compressed history for on-device context
  memorySnapshot  Json      @default("{}")           // last 30 days summary
  lastBuiltAt     DateTime?

  // Downloadable artifact version
  version         Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Activity {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  clientActivityId String?
  syncSource    String?   // ios-local-store, watch-import, manual

  type          String    // running | cycling | hiking | swimming
  title         String?
  startedAt     DateTime
  endedAt       DateTime?
  durationSecs  Int?
  distanceM     Float?
  elevationM    Float?
  avgPace       Float?    // secs/km
  avgHeartRate  Int?
  calories      Int?

  route         Json?     // GeoJSON LineString
  splits        Json?     // Split[]
  photos        Photo[]
  posts         Post[]

  // AI coach analysis generated after activity
  coachAnalysis Json?

  createdAt     DateTime  @default(now())

  @@unique([userId, clientActivityId])
}

model ActiveTrainingPlan {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id])

  templateId          String
  focus               String
  sport               String
  title               String
  subtitle            String
  durationWeeks       Int
  sessionsPerWeek     Int
  targetWeeklyMinutes Int
  longSessionMinutes  Int
  startedAt           DateTime  @default(now())

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model TrainingPlanTemplate {
  id                     String    @id
  focus                  String
  sport                  String
  title                  String
  subtitle               String
  defaultWeeks           Int
  minSessionsPerWeek     Int
  maxSessionsPerWeek     Int
  baseWeeklyMinutes      Int
  baseLongSessionMinutes Int
  summary                String
  highlights             String[]  @default([])
  source                 Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  weeks                  TrainingPlanWeek[]

  @@index([focus])
  @@index([sport])
}

model TrainingPlanWeek {
  id          String    @id @default(cuid())
  templateId  String
  template    TrainingPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sourceId    String
  weekIndex   Int
  focus       String
  summary     String
  notes       String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workouts    TrainingPlanWorkout[]

  @@unique([templateId, sourceId])
  @@unique([templateId, weekIndex])
  @@index([templateId])
}

model TrainingPlanWorkout {
  id              String    @id @default(cuid())
  weekId          String
  week            TrainingPlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  sourceId        String
  sortOrder       Int
  title           String
  kind            String
  dayLabel        String
  summary         String
  purpose         String
  coachCue        String
  effortLabel     String
  durationSeconds Int
  distanceLabel   String?
  isOptional      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  steps           TrainingPlanWorkoutStep[]

  @@unique([weekId, sourceId])
  @@index([weekId, sortOrder])
}

model TrainingPlanWorkoutStep {
  id              String    @id @default(cuid())
  workoutId       String
  workout         TrainingPlanWorkout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sourceId        String
  sortOrder       Int
  kind            String
  label           String
  durationSeconds Int
  detail          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([workoutId, sourceId])
  @@index([workoutId, sortOrder])
}

model Photo {
  id          String    @id @default(cuid())
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id])
  url         String
  takenAt     DateTime
  // Stats at moment of capture
  paceAtShot  Float?
  hrAtShot    Int?
  distAtShot  Float?
  lat         Float?
  lng         Float?
  createdAt   DateTime  @default(now())
}

model Post {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  activityId  String?
  activity    Activity?  @relation(fields: [activityId], references: [id])
  caption     String?
  createdAt   DateTime   @default(now())
  reactions   Reaction[]
  comments    Comment[]
}

model Follow {
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id])
  following   User   @relation("following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Reaction {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
  type      String   // fire | clap | heart | strong
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  authorId  String
  body      String
  createdAt DateTime @default(now())
}
